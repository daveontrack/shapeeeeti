# Email Configuration - Add these to your .env.local file

# ==========================================
# RESEND - For Donation Thank You Emails
# ==========================================
# Sign up at: https://resend.com
# Get API key from: https://app.resend.com/api-keys
RESEND_API_KEY=re_G6jNNB5r_CxodxpGUXTa5yvGnrr7TjwhR

# ==========================================
# SUPABASE SMTP - For Email Confirmation
# Configure directly in Supabase Dashboard:
# https://app.supabase.com → Authentication → Email Templates → Configure SMTP
# ==========================================

# Gmail Example (using App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM="SHAPEthiopia <your-email@gmail.com>"

# SendGrid Example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# SMTP_FROM="SHAPEthiopia <verified-sender@yourdomain.com>"

# ==========================================
# Optional: App URL (for email links)
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
